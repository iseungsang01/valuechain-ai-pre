<file path="calc.py">
class Calculator:
    def add(self, a, b):
        return a + b

    def subtract(self, a, b):
        return a - b
</file>
<file path="test_calc.py">
from calc import Calculator

def test_calculator():
    calc = Calculator()
    
    # Test add
    assert calc.add(2, 3) == 5, "2 + 3 should be 5"
    assert calc.add(-1, 1) == 0, "-1 + 1 should be 0"
    assert calc.add(0, 0) == 0, "0 + 0 should be 0"
    
    # Test subtract
    assert calc.subtract(5, 3) == 2, "5 - 3 should be 2"
    assert calc.subtract(10, 20) == -10, "10 - 20 should be -10"
    assert calc.subtract(0, 0) == 0, "0 - 0 should be 0"
    
    print("All tests passed!")

if __name__ == "__main__":
    test_calculator()
